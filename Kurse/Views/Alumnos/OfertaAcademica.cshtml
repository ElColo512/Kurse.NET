<div class="container-fluid">
    <div class="mb-4">
        <h2 class="fw-bold">Oferta Académica</h2>
        <p class="text-secondary mb-0">
            Explora los cursos disponibles e inscríbete.
        </p>
    </div>

    <div class="row g-4">
        @foreach (var curso in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 curso-card shadow-sm">
                    <div class="curso-banner">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <small class="text-secondary">@curso.Codigo</small>
                                <h5 class="card-title fw-bold mb-1">@curso.NombreCurso</h5>
                                <small class="text-muted">@curso.Profesor</small>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                @if (curso.Arancelado)
                                {
                                    <span class="badge bg-warning text-dark">Arancelado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Gratuito</span>
                                }

                                @if (curso.YaInscripto)
                                {
                                    <span class="badge bg-purple">Inscripto</span>
                                }
                            </div>
                        </div>

                        <hr />

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <small class="text-secondary d-block"><i class="bi bi-calendar-week me-1"></i> Días</small>
                                <span class="fw-semibold">@curso.DiasDictado</span>
                            </div>

                            <div class="col-6">
                                <small class="text-secondary d-block"><i class="bi bi-clock me-1"></i> Horario</small>
                                <span class="fw-semibold">@curso.HoraInicio.ToString("HH:mm") - @curso.HoraFin.ToString("HH:mm")</span>
                            </div>

                            <div class="col-6">
                                <small class="text-secondary d-block"><i class="bi bi-calendar-event me-1"></i> Inicio</small>
                                <span class="fw-semibold">@curso.FechaInicio.ToString("dd/MM/yyyy")</span>
                            </div>

                            <div class="col-6">
                                <small class="text-secondary d-block"><i class="bi bi-hourglass-split me-1"></i> Duración</small>
                                <span class="fw-semibold">@curso.DuracionHoras hs</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-circle">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                            <span>@curso.LugarDictado</span>
                        </div>

                        <div>
                            <div class="d-flex justify-content-between mb-2">
                                <small class="text-secondary">Cupos ocupados</small>
                                <small class="fw-semibold contador-inscriptos" data-inscriptos="@curso.CantidadInscriptos" data-cupo="@curso.CupoMaximo">@curso.CantidadInscriptos / @curso.CupoMaximo</small>
                            </div>

                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width:@((curso.CantidadInscriptos * 100) / curso.CupoMaximo)%"></div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pb-3">
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary flex-fill btn-detalle" data-id="@curso.CursoId"><i class="bi bi-eye me-1"></i> Detalle</button>
                            @if (curso.YaInscripto)
                            {
                                <button class="btn btn-secondary flex-fill" disabled><i class="bi bi-check-circle-fill me-1"></i> Inscripto</button>
                            }
                            else
                            {
                                <button class="btn btn-success flex-fill btn-inscribirse" data-id="@curso.CursoId"><i class="bi bi-check-circle me-1"></i> Inscribirme</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="modalCursos" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" id="contenidoModal">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        initializeDetailsModal({
            buttonClass: '.btn-detalle',
            url: '/Cursos/Details',
            modalId: 'modalCursos',
            contentContainer: '#contenidoModal'
        });

        
        $(document).on('click', '.btn-inscribirse', function () {
            const button = $(this);
            const cursoId = $(this).data('id');

            Swal.fire({
                title: '¿Desea inscribirse?',
                text: 'Se registrará su inscripción al curso.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Inscribirme',
                cancelButtonText: 'Cancelar'
            }).then(result => {
                if (!result.isConfirmed)
                    return;

                $.ajax({
                    url: '/Alumnos/Inscribirse',
                    type: 'POST',
                    data: {
                        cursoId: cursoId
                    },
                    headers: {'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()},
                    success: function (response) {
                        if (response.success) {
                            showToast(response.message, 'success');
                            button.removeClass('btn-success').addClass('btn-secondary').prop('disabled', true).html('<i class="bi bi-check-circle"></i> Inscripto');

                        // Actualizar contador
                             const contador = button.closest('.card').find('.contador-inscriptos');
                             let inscriptos = parseInt(contador.data('inscriptos'));
                             const cupo = parseInt(contador.data('cupo'));
                             inscriptos++;
                             contador.data('inscriptos', inscriptos);
                             contador.text(`${inscriptos} / ${cupo}`);
                             const porcentaje = (inscriptos * 100) / cupo;
                             const barra = button.closest('.card').find('.progress-bar');
                             barra.css('width', porcentaje + '%');
                             barra.attr('aria-valuenow', porcentaje);
                        }
                        else {
                            showToast(response.message, 'warning');
                        }
                    },
                    error: xhr => handleAjaxError(xhr, 'No se pudo realizar la inscripción.')
                });
            });
        });
    </script>
}