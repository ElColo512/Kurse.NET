@model HistoriaCursoViewModel

<div class="col-md-6 col-xl-4">
    <div class="card h-100 historia-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <h5 class="fw-bold mb-0">@Model.NombreCurso</h5>

                @switch (Model.Estado)
                {
                    case EstadoAcademico.Aprobado:
                        <span class="badge bg-success">Aprobado</span>
                        break;

                    case EstadoAcademico.Desaprobado:
                        <span class="badge bg-danger">Desaprobado</span>
                        break;

                    case EstadoAcademico.Inscripto:
                        <span class="badge bg-primary">En Curso</span>
                        break;

                    default:
                        <span class="badge bg-secondary">@Model.Estado</span>
                        break;
                }
            </div>

            <hr />

            <p>
                <i class="bi bi-person"></i> @Model.Profesor
            </p>

            <p>
                <i class="bi bi-calendar-event"></i> @Model.FechaInicio - @Model.FechaFin
            </p>

            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <small>Asistencia</small>
                    <small>
                        @Model.Asistencia / @Model.CantidadClases
                        (@Model.PorcentajeAsistencia%)
                    </small>
                </div>

                <div class="progress">
                    <div class="progress-bar" style="width:@Model.PorcentajeAsistencia%"></div>
                </div>
            </div>

            @if (Model.NotaFinal.HasValue)
            {
                <div class="d-flex align-items-center gap-3">
                    <span class="text-secondary">Nota Final</span>
                    <div class="nota-final">
                        @Model.NotaFinal
                    </div>
                </div>
            }
        </div>

        <div class="card-footer bg-transparent">
            @if (Model.PuedeDescargarCertificado)
            {
                <a asp-action="Certificado" asp-route-cursoId="@Model.CursoId" class="btn btn-outline-success w-100"><i class="bi bi-award me-2"></i> Descargar Certificado</a>
            }
        </div>
    </div>
</div>