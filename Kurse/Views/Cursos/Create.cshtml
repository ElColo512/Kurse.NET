@model CreateCursoViewModel
@{
    ViewData["Title"] = "Nuevo Curso";
}

<div class="container">
    <div class="card shadow-sm">
        <div class="card-header">
            <h3 class="mb-0">@ViewData["Title"]</h3>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <partial name="_CursoForm" model="Model" />

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Cancelar</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i> Guardar Curso</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        initializeToggleField('#chkArancelado', '#contenedorArancel', '#Arancel');
    </script>
    <partial name="_ValidationScriptsPartial" />
}