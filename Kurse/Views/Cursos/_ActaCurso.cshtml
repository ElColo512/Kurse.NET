@model CursoActaViewModel

<form id="formActa" data-finalizado="@Model.EstaFinalizado.ToString().ToLower()">
    <input type="hidden" name="CursoId" value="@Model.CursoId" />
    <div class="modal-header">
        <h5 class="modal-title">Acta - @Model.NombreCurso</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    @if (Model.EstaFinalizado)
    {
        <div class="alert alert-info">
            <i class="bi bi-lock-fill me-2"></i>
            El curso se encuentra finalizado. El acta es de solo lectura.
        </div>
    }

    <div class="modal-body">
        <div class="table-responsive">
            <div class="mt-4">
                @await Component.InvokeAsync("DataTable", new DataTableViewModel
                {
                    TableId = "tablaActa",
                    Columns = new()
                    {
                        "Alumno",
                        "Asistencia",
                        "Nota",
                        "Estado",
                        "Acciones"
                    }
                })
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary" disabled="@Model.EstaFinalizado"><i class="bi bi-floppy me-1"></i> Guardar Acta</button>
    </div>
</form>